{
  "info": {
    "_postman_id": "ctse-lab-05-microservices",
    "name": "Microservices Lab",
    "description": "CTSE Lab 05 — All endpoints routed through the API Gateway on port 8080.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Item Service",
      "item": [
        {
          "name": "GET All Items",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/items",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["items"]
            },
            "description": "Returns the list of all items stored in the Item Service."
          },
          "response": []
        },
        {
          "name": "POST Add Item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "text/plain"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "Headphones"
            },
            "url": {
              "raw": "http://localhost:8080/items",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["items"]
            },
            "description": "Adds a new item. Send the item name as plain text in the request body."
          },
          "response": []
        },
        {
          "name": "GET Item by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/items/0",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["items", "0"]
            },
            "description": "Retrieves an item by its index (0-based). Default items: 0=Book, 1=Laptop, 2=Phone."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Order Service",
      "item": [
        {
          "name": "GET All Orders",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/orders",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["orders"]
            },
            "description": "Returns all placed orders."
          },
          "response": []
        },
        {
          "name": "POST Place Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"item\": \"Laptop\",\n  \"quantity\": 2,\n  \"customerId\": \"C001\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:8080/orders",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["orders"]
            },
            "description": "Places a new order. Returns the order with auto-generated id and status PENDING."
          },
          "response": []
        },
        {
          "name": "GET Order by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/orders/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["orders", "1"]
            },
            "description": "Retrieves a specific order by its auto-generated integer ID."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Payment Service",
      "item": [
        {
          "name": "GET All Payments",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/payments",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["payments"]
            },
            "description": "Returns all processed payments."
          },
          "response": []
        },
        {
          "name": "POST Process Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": 1,\n  \"amount\": 1299.99,\n  \"method\": \"CARD\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:8080/payments/process",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["payments", "process"]
            },
            "description": "Processes a payment. Returns the payment record with auto-generated id and status SUCCESS."
          },
          "response": []
        },
        {
          "name": "GET Payment by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/payments/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["payments", "1"]
            },
            "description": "Retrieves a specific payment by its auto-generated integer ID."
          },
          "response": []
        }
      ]
    }
  ]
}
